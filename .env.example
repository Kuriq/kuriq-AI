# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=30

# Internal Security
# Must match backend INTERNAL_API_KEY.
INTERNAL_SECRET_KEY=change-me

# RAG Configuration
RAG_TOP_K=20

# ChromaDB Configuration
CHROMA_MODE=server
CHROMA_PATH=./chroma_db
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Crawler Data Service
CRAWLER_DATA_BASE_URL=http://localhost:8001
CRAWLER_DATA_TIMEOUT=30

# For docker compose deployments, override with service DNS names instead.
# CHROMA_HOST=chroma
# CRAWLER_DATA_BASE_URL=http://kuriq-data:8001
